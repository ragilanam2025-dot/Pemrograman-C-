Program diminta menghitung dan menampilkan keliling serta luas dari segitiga tersebut.
Code :
#include <iostream>
using namespace std;
 
int main() {
    // Deklarasi variabel
    float sisi1 = 7, sisi2 = 7, sisi3 = 6; // tiga sisi segitiga (diasumsikan sisi1 dan sisi2 sama)
    float alas = 6, tinggi = 4;
    float keliling, luas;
 
    // Rumus keliling segitiga
    keliling = sisi1 + sisi2 + sisi3;
 
    // Rumus luas segitiga
    luas = 0.5 * alas * tinggi;
 
    // Menampilkan hasil
    cout << "Ragil Anam Winarya_25051030053" << endl;
    cout << "=== Program Menghitung Keliling dan Luas Segitiga ===" << endl;
    cout << "Sisi 1 : " << sisi1 << " cm" << endl;
    cout << "Sisi 2 : " << sisi2 << " cm" << endl;
    cout << "Sisi 3 : " << sisi3 << " cm" << endl;
    cout << "Alas   : " << alas << " cm" << endl;
    cout << "Tinggi : " << tinggi << " cm" << endl;
    cout << "---------------------------------------------" << endl;
    cout << "Keliling Segitiga = " << keliling << " cm" << endl;
    cout << "Luas Segitiga     = " << luas << " cm²" << endl;
 
    return 0;
}
 
