Declare Many Variables adalah membuat beberapa variabel sekaligus dalam satu baris kode dengan tipe data yang sama.
Contoh :
#include <iostream>
using namespace std;
 
int main() {
    int a, b, c;  // mendeklarasikan 3 variabel integer
    a = 10;
    b = 20;
    c = 30;
 
    cout << "a = " << a << ", b = " << b << ", c = " << c << endl;
    return 0;
}
