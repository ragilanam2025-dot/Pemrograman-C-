Cin adalah bahasa pada C++ untuk menerima input (masukan) dari pengguna lewat keyboard.
Contoh :
#include <iostream>
 
int main() {
    std::string nama = "Ragil Anam Winarya"; 
    int umur = 18;                          
 
    std::cout << "=== Data Saya ===\n";
    std::cout << "Nama: " << nama   << '\n';
    std::cout << "Umur: " << umur   << " tahun\n";
 
    return 0;
}
 
